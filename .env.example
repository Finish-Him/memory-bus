# Memory Bus — Environment
# Copy to .env and fill in values

# Database (KVM2 Supabase self-hosted)
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@localhost:5432/memory_bus

# OpenAI (embeddings)
OPENAI_API_KEY=sk-...

# API security
API_KEY=memory-bus-secret-key-change-me

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Embedding config
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Hybrid search
HYBRID_DEFAULT_K=10
HYBRID_VECTOR_WEIGHT=0.7
HYBRID_BM25_WEIGHT=0.3
